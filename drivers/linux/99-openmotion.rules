# /etc/udev/rules.d/99-openmotion.rules
# ──────────────────────────────────────────────────────────────────────
#  udev rules for OpenMotion USB devices (STM32-based)
#
#  Grants non-root users in the "plugdev" group access to the sensor
#  modules, console module, and DFU bootloader.
#
#  Install:  sudo cp 99-openmotion.rules /etc/udev/rules.d/
#            sudo udevadm control --reload-rules
#            sudo udevadm trigger
#
#  Or run:   sudo ./install.sh
# ──────────────────────────────────────────────────────────────────────

# ── Sensor Module (composite: command + histogram + IMU) ──────────────
# VID 0x0483 (STMicroelectronics), PID 0x5A5A
# Three interfaces: MI_00 (command), MI_01 (histogram stream), MI_02 (IMU)
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="5a5a", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# ── Console Module (CDC / Virtual COM Port) ───────────────────────────
# VID 0x0483, PID 0xA53E
# Enumerates as /dev/ttyACM* — grant access to plugdev group
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="a53e", MODE="0666", GROUP="plugdev", TAG+="uaccess"
# Also match the tty device node created by the cdc_acm driver
SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="a53e", MODE="0666", GROUP="plugdev", SYMLINK+="openmotion-console"

# ── DFU Bootloader (firmware update mode) ─────────────────────────────
# VID 0x0483, PID 0xDF11 (standard STM32 ROM DFU)
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="df11", MODE="0666", GROUP="plugdev", TAG+="uaccess"
